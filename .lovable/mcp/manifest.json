{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://ldocprioqcxxzadisoii.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "echat-mcp",
      "version": "0.1.0",
      "title": "Echat"
    },
    "tools": [
      {
        "name": "whoami",
        "title": "Who am I",
        "description": "Return the signed-in Echat user's profile (id, username, name, bio).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_recent_chats",
        "title": "List recent chats",
        "description": "List the signed-in user's most recent 1-to-1 Echat chats, ordered by last message time.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max number of chats to return (default 20).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_messages",
        "title": "List chat messages",
        "description": "List the most recent messages in a 1-to-1 Echat chat by chat_id (RLS enforces access).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "chat_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "The Echat chat id (UUID)."
            },
            "limit": {
              "description": "Max messages (default 50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          },
          "required": [
            "chat_id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "search_users",
        "title": "Search Echat users",
        "description": "Search Echat users by username or display name (case-insensitive). Returns public profile fields only.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "description": "Username or name fragment."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 25
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "save_note",
        "title": "Save a note to Saved Messages",
        "description": "Save a personal text note to the user's Echat Saved Messages.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "note": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4000,
              "description": "The note text to save."
            }
          },
          "required": [
            "note"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
